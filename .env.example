NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Canonical site URL — used for OAuth + magic-link redirectTo.
# In production, set this to your Vercel domain (no trailing slash):
#   NEXT_PUBLIC_SITE_URL=https://flowpilot-ai.vercel.app
# In local dev you can leave it unset; the client falls back to window.location.origin.
NEXT_PUBLIC_SITE_URL=

OPENAI_API_KEY=sk-...

# Seylan Bank sandbox (provided by buildathon organizers)
# Sandbox is HTTP not HTTPS — do not change to https://
SEYLAN_API_BASE_URL=
SEYLAN_API_KEY=
SEYLAN_MODE=live              # 'live' uses sandbox; 'simulator' uses local mocks
SEYLAN_TEST_SOURCE_ACCOUNT=
SEYLAN_TEST_INTERNAL_DEST=
SEYLAN_TEST_CEFTS_DEST_ACCOUNT=
SEYLAN_TEST_CEFTS_DEST_BANK=
SEYLAN_REQUEST_TIMEOUT_MS=20000

# Mastercard Payment Gateway (MPGS) — from buildathon Seylan team
# Login: https://test-seylan.mtf.gateway.mastercard.com/ma/login.s
MPGS_BASE_URL=
MPGS_API_VERSION=                    # e.g. 73 — from MPGS integration guide
MPGS_MERCHANT_ID=                    # e.g. TESTCURSOR2
MPGS_API_PASSWORD=                   # generated in MPGS portal → Admin → Operators
MPGS_RETURN_URL_BASE=                # localhost in dev, Vercel URL in prod
MPGS_CURRENCY=LKR
